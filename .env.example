# MCP service identity
MCP_SERVICE_NAME=Poco MCP Service

# http | stdio
MCP_TRANSPORT=http
MCP_HOST=0.0.0.0
MCP_PORT=8090

# Backend API
BACKEND_BASE_URL=http://127.0.0.1:8000/api/v1
# Optional fallback for non-HTTP-context calls (e.g. local direct tests)
BACKEND_ADMIN_API_KEY=
# Optional for future global-scope MCP tools
BACKEND_GLOBAL_API_KEY=
BACKEND_TIMEOUT_SECONDS=20

# Analytics defaults
ANALYTICS_DEFAULT_TIMEZONE=Asia/Shanghai
ANALYTICS_DEFAULT_TOP_LIMIT=10
